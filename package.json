{
  "name": "@dcyfr/ai-kubernetes",
  "private": true,
  "version": "1.0.1",
  "description": "Kubernetes deployment toolkit — generate, validate, and manage K8s manifests and Helm charts with @dcyfr/ai",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manifests": {
      "types": "./dist/manifests/index.d.ts",
      "import": "./dist/manifests/index.js"
    },
    "./helm": {
      "types": "./dist/helm/index.d.ts",
      "import": "./dist/helm/index.js"
    },
    "./health": {
      "types": "./dist/health/index.d.ts",
      "import": "./dist/health/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "node scripts/lint.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "kubernetes",
    "k8s",
    "helm",
    "deployment",
    "manifests",
    "dcyfr",
    "ai",
    "devops"
  ],
  "author": "DCYFR Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dcyfr-labs/dcyfr-ai-kubernetes"
  },
  "bugs": {
    "url": "https://github.com/dcyfr-labs/dcyfr-ai-kubernetes/issues"
  },
  "homepage": "https://github.com/dcyfr-labs/dcyfr-ai-kubernetes#readme",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4"
  }
}
